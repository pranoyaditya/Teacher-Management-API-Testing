      "name": "Teachers CRUD",
      "item": [
        {
          "name": "New teacher creation vs response validation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Teacher id creation.\r",
                  "const teacherId = Math.floor(Math.random() * 100000);\r",
                  "pm.environment.set(\"teacherId\", teacherId);\r",
                  "\r",
                  "// Creating random department for teacher.\r",
                  "let departments = [\"CSE\", \"BBA\", \"MBA\", \"LAW\", \"PHARMACY\", \"ENGLISH\"];\r",
                  "let randomDepartment = departments[Math.floor(Math.random() * departments.length)];\r",
                  "pm.environment.set(\"department\", randomDepartment);\r",
                  "\r",
                  "// Selecting random designations for teacher.\r",
                  "let designations = [\"Professor\", \"Associate Professor\", \"Assistant Professor\", \"Lecturer\", \"Instructor\"];\r",
                  "let randomDesignation = designations[Math.floor(Math.random() * designations.length)];\r",
                  "pm.environment.set(\"designation\", randomDesignation);\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Status code validation.\r",
                  "pm.test(\"Status code is 201/200\", () => {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "// Id exist in response validation.\r",
                  "pm.test(\"ID exist in response body\", () => {\r",
                  "    pm.expect(pm.response.json()._id).not.to.be.null;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// Response body vs Request body validation code.\r",
                  "const responseData = pm.response.json();\r",
                  "const requestData = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "// Teacher name matches in both response and request validation code\r",
                  "pm.test(\"Teacher name matches in both response and request\", () => {\r",
                  "    pm.expect(responseData.name).to.eql(requestData.name);\r",
                  "});\r",
                  "\r",
                  "// Teacher email matches in both response and request validation code \r",
                  "pm.test(\"Teacher email mathces in both response and request\", () => {\r",
                  "    pm.expect(responseData.email).to.eql(requestData.email);\r",
                  "});\r",
                  "\r",
                  "// Teacher department matches in both response and request validation code.\r",
                  "pm.test(\"Teacher department matches in both response and request\", () => {\r",
                  "    pm.expect(responseData.department).to.eql(requestData.department);\r",
                  "});\r",
                  "\r",
                  "// Teacher Id matches in both response and request validation code.\r",
                  "pm.test(\"Teacher Id matches in both response and request\", () => {\r",
                  "    pm.expect(responseData.teacherId).to.eql(requestData.teacherId);\r",
                  "});\r",
                  "\r",
                  "// Teacher designation matches in both response and request validation code.\r",
                  "pm.test(\"Teacher designation matches in both response and request\", () => {\r",
                  "    pm.expect(responseData.designation).to.eql(requestData.designation);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
