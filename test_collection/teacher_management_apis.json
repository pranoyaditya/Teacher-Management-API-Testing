        {
          "name": "All teacher list api",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Response code test\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "})\r",
                  "\r",
                  "// Valid schema structure\r",
                  "const schema = {\r",
                  "    \"type\": \"array\",\r",
                  "    \"items\": {\r",
                  "        \"type\": \"object\",\r",
                  "        \"required\": [\"_id\", \"name\", \"email\", \"designation\", \"teacherId\", \"department\"],\r",
                  "        \"properties\": {\r",
                  "            \"_id\": { \"type\": \"string\" },\r",
                  "            \"name\": { \"type\": \"string\" },\r",
                  "            \"email\": { \"type\": \"string\" },\r",
                  "            \"designation\": { \"type\": \"string\" },\r",
                  "            \"teacherId\": { \"type\": \"number\" },\r",
                  "            \"department\": { \"type\": \"string\" }\r",
                  "        }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "let responseData = pm.response.json();\r",
                  "\r",
                  "// Storing random email in environment variables\r",
                  "const index = Math.floor(Math.random() * responseData.length);\r",
                  "pm.environment.set(\"randomEmail\", responseData[index].email);\r",
                  "\r",
                  "// Schema validation test code.\r",
                  "pm.test(\"Schema is valid\", () => {\r",
                  "    let valid = tv4.validate(responseData, schema);\r",
                  "    pm.expect(valid).to.be.true;\r",
                  "});\r",
                  "\r",
                  "// Validate teacherId from environment variables exist in response.\r",
                  "pm.test(\"teacherId from environment variables exist in response\", () => {\r",
                  "    let teacherId = pm.environment.get(\"teacherId\");\r",
                  "    let found = false;\r",
                  "    responseData.forEach((teacher) => {\r",
                  "        if(teacher.teacherId == teacherId) {\r",
                  "            found = true;\r",
                  "            return;\r",
                  "        }\r",
                  "    });\r",
                  "    pm.expect(found).to.be.true;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
