          "name": "Authorization token validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const login_token = pm.response.json().authToken;\r",
                  "pm.environment.set(\"token\", login_token);\r",
                  "\r",
                  "// Status code validation code.\r",
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "// Token exists in response validation code.\r",
                  "pm.test(\"Token exists in response\", () => {\r",
                  "    pm.expect(login_token).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "// Token isn't empty validation code.\r",
                  "pm.test(\"Token is not empty\", () => {\r",
                  "    pm.expect(login_token).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
